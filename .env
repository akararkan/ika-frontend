# =========================================================
# IKA — backend connection
# ---------------------------------------------------------
# Your backend:  host = localhost,  port = 8080,  api base = /api/v1
#
# IMPORTANT: VITE_API_BASE_URL must be ONLY the host+port
# (http://localhost:8080). The "/api/v1/..." part is already
# included in every request path inside the app, so do NOT add
# it here (that would become /api/v1/api/v1/...).
#
# The client then calls http://localhost:8080/api/v1/...
# directly. Your backend allows CORS from http://localhost:5173
# with credentials, so cookies + the IRC_TOKEN flow correctly.
#
# ⚠️  After editing this file you MUST restart `npm run dev`
#     (Vite reads .env only at startup), and run the app on
#     port 5173 (the origin your backend's CORS allows).
# =========================================================

VITE_API_BASE_URL=http://localhost:8080
