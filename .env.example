# =========================================================
# IKA — frontend environment
# Copy this to `.env.local` for local development.
# =========================================================
#
# THREE deploy modes:
#
# 1) Local dev with the Vite proxy (recommended for laptop work)
#    .env.local:
#      VITE_API_BASE_URL=
#      VITE_DEV_PROXY=http://localhost:8080
#    Browser hits /api/... → Vite proxies to your local backend.
#    Works on phone too (Vite prints a LAN URL on `npm run dev`).
#
# 2) Local dev hitting the Railway backend directly (no local API)
#    .env.local:
#      VITE_API_BASE_URL=https://irc-bakend-production.up.railway.app
#    Backend must allow CORS from http://localhost:5173 (or wherever
#    Vite serves you).
#
# 3) Production build for Vercel
#    .env.production already has VITE_API_BASE_URL empty. The
#    vercel.json rewrites /api/* → Railway, so the browser stays
#    same-origin (no CORS, no mixed content). Just `git push` —
#    Vercel runs `npm run build` and serves the result.
#
# =========================================================

# Backend URL (no trailing slash). Empty = relative /api/... URLs.
VITE_API_BASE_URL=

# Dev-only: when set, `npm run dev` proxies /api → this URL.
# Ignored by `npm run build`.
# VITE_DEV_PROXY=http://localhost:8080
